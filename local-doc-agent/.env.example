LOCAL_DOC_AGENT_HOST=127.0.0.1
LOCAL_DOC_AGENT_PORT=2091
LOCAL_DOC_AGENT_WORKSPACE=workspace
LOCAL_DOC_AGENT_LOGS=logs
LOCAL_DOC_AGENT_DEFAULT_OVERWRITE=true
LOCAL_DOC_AGENT_CREATE_BACKUP=true
LOCAL_DOC_AGENT_MAX_READ_CHARS=50000

# Runtime UTF-8 guard.
# PYTHONUTF8/PYTHONIOENCODING must be set before Python starts.
# On Windows, prefer scripts/start_server.ps1 for server launch.
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
